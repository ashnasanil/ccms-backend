{
  "ConnectionStrings": {
    "DefaultConnection": "server=localhost;port=3306;database=ccms_batch_db;user=root;password=root;"
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/ccms-api-log.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Secret": "SuperSecretKeyCCMSBackend2026SecureAuth"
  },
  "AzureBlobStorage": {
    "ConnectionString": "",
    "ContainerName": "attachments"
  }
}
